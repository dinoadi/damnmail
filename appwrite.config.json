{
    "projectId": "damnmail",
    "endpoint": "https://sgp.cloud.appwrite.io/v1",
    "functions": [
        {
            "$id": "api",
            "name": "API",
            "runtime": "node-22",
            "path": "apps/functions/api",
            "entrypoint": "src/index.ts",
            "execute": ["any"],
            "enabled": true,
            "logging": true,
            "events": [],
            "schedule": "",
            "timeout": 30,
            "commands": "npm install",
            "scopes": [
                "databases.read", "databases.write",
                "documents.read", "documents.write",
                "collections.read", "collections.write"
            ],
            "buildSpecification": "s-0.5vcpu-512mb",
            "runtimeSpecification": "s-0.5vcpu-512mb",
            "deploymentRetention": 0
        },
        {
            "$id": "telegram-bot",
            "name": "Telegram Bot",
            "runtime": "node-22",
            "path": "apps/functions/telegram-bot",
            "entrypoint": "src/index.ts",
            "execute": ["any"],
            "enabled": true,
            "logging": true,
            "events": [],
            "schedule": "",
            "timeout": 30,
            "commands": "npm install",
            "scopes": [
                "databases.read", "databases.write",
                "documents.read", "documents.write",
                "collections.read", "collections.write"
            ],
            "buildSpecification": "s-0.5vcpu-512mb",
            "runtimeSpecification": "s-0.5vcpu-512mb",
            "deploymentRetention": 0
        },
        {
            "$id": "process-email",
            "name": "Process Email",
            "runtime": "node-22",
            "path": "apps/functions/process-email",
            "entrypoint": "src/index.ts",
            "execute": ["any"],
            "enabled": true,
            "logging": true,
            "events": [],
            "schedule": "",
            "timeout": 30,
            "commands": "npm install",
            "scopes": [
                "databases.read", "databases.write",
                "documents.read", "documents.write",
                "collections.read", "collections.write"
            ],
            "buildSpecification": "s-0.5vcpu-512mb",
            "runtimeSpecification": "s-0.5vcpu-512mb",
            "deploymentRetention": 0
        },
        {
            "$id": "cleanup",
            "name": "Cleanup",
            "runtime": "node-22",
            "path": "apps/functions/cleanup",
            "entrypoint": "src/index.ts",
            "execute": ["any"],
            "enabled": true,
            "logging": true,
            "events": [],
            "schedule": "0 */6 * * *",
            "timeout": 30,
            "commands": "npm install",
            "scopes": [
                "databases.read", "databases.write",
                "documents.read", "documents.write",
                "collections.read", "collections.write"
            ],
            "buildSpecification": "s-0.5vcpu-512mb",
            "runtimeSpecification": "s-0.5vcpu-512mb",
            "deploymentRetention": 0
        },
        {
            "$id": "test-env",
            "name": "Test Env",
            "runtime": "node-22",
            "path": "apps/functions/test-env",
            "entrypoint": "src/index.ts",
            "execute": ["any"],
            "enabled": true,
            "logging": true,
            "events": [],
            "schedule": "",
            "timeout": 15,
            "commands": "",
            "scopes": [
                "databases.read", "databases.write",
                "documents.read", "documents.write"
            ],
            "buildSpecification": "s-0.5vcpu-512mb",
            "runtimeSpecification": "s-0.5vcpu-512mb",
            "deploymentRetention": 0
        },
        {
            "$id": "telegram-poller",
            "name": "telegram-poller",
            "runtime": "node-22",
            "path": "apps/functions/telegram-poller",
            "entrypoint": "src/index.ts",
            "execute": ["any"],
            "enabled": true,
            "logging": true,
            "events": [],
            "schedule": "* * * * *",
            "timeout": 30,
            "commands": "npm install",
            "scopes": [
                "databases.read", "databases.write",
                "documents.read", "documents.write",
                "collections.read", "collections.write"
            ],
            "buildSpecification": "s-0.5vcpu-512mb",
            "runtimeSpecification": "s-0.5vcpu-512mb",
            "deploymentRetention": 0
        }
    ],
    "hosting": {
        "name": "dashboard",
        "domain": "readyonbooking.app",
        "source": "./apps/frontend/out",
        "functionRoutes": [
            {
                "path": "/api/*",
                "functionId": "api"
            }
        ]
    },
    "sites": [
    {
      "$id": "dashboard",
      "path": "./",
      "name": "Damnmail Dashboard",
      "framework": "other",
      "enabled": true,
      "logging": true,
      "outputDirectory": "apps/frontend/out",
      "installCommand": "pnpm install",
      "buildCommand": "pnpm --filter @damnmail/frontend run build",
      "deploymentRetention": 0
    }
    ]
}
